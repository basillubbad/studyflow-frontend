generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @db.VarChar(36)
  name                 String      @db.VarChar(191)
  email                String      @unique @db.VarChar(191)
  passwordHash         String      @db.Text
  university           String      @db.VarChar(191)
  major                String      @db.VarChar(191)
  academicYear         String      @db.VarChar(191)
  currentGPA           String      @db.VarChar(50)
  totalCreditHours     String      @db.VarChar(50)
  completedCreditHours String      @db.VarChar(50)
  onboardingCompleted  Boolean     @default(false)
  avatarUrl            String?     @db.Text
  focusPreferences     Json
  reminderPreferences  Json
  themePreference      String      @db.VarChar(20)
  resetToken           String?     @db.VarChar(191)
  resetTokenExpiresAt  DateTime?
  createdAt            DateTime
  updatedAt            DateTime    @updatedAt
  appData              UserAppData?

  @@map("users")
}

model UserAppData {
  userId            String   @id @db.VarChar(36)
  semesters         Json
  courses           Json
  tasks             Json
  reflections       Json
  notifications     Json
  focusSessions     Json
  selfLearningPlans Json
  examPrepByItemId  Json
  detachedResources Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_app_data")
}
